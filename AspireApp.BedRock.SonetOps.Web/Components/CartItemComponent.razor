@using AspireApp.BedRock.SonetOps.Web.Models

<div class="cart-item">
    <div class="item-image">
        <img src="@Item.ImageUrl" alt="@Item.Name" />
    </div>
    
    <div class="item-details">
        <h4>@Item.Name</h4>
        <p class="price">@Item.Price.ToString("C")</p>
    </div>

    <div class="item-quantity">
        <button class="btn btn-sm btn-outline-secondary" 
                @onclick="@(() => UpdateQuantity(Item.Quantity - 1))"
                disabled="@(Item.Quantity <= 1)">
            -
        </button>
        <span class="quantity">@Item.Quantity</span>
        <button class="btn btn-sm btn-outline-secondary" 
                @onclick="@(() => UpdateQuantity(Item.Quantity + 1))">
            +
        </button>
    </div>

    <div class="item-total">
        @((Item.Price * Item.Quantity).ToString("C"))
    </div>

    <button class="btn btn-sm btn-danger remove-button" @onclick="OnRemove">
        Remove
    </button>
</div>

@code {
    [Parameter]
    public CartItem Item { get; set; }

    [Parameter]
    public EventCallback<int> OnUpdateQuantity { get; set; }

    [Parameter]
    public EventCallback OnRemove { get; set; }

    private async Task UpdateQuantity(int newQuantity)
    {
        if (newQuantity >= 1)
        {
            await OnUpdateQuantity.InvokeAsync(newQuantity);
        }
    }
}

<style>
.cart-item {
    display: flex;
    align-items: center;
    padding: 15px;
    border-bottom: 1px solid #dee2e6;
    gap: 15px;
}

.item-image {
    width: 80px;
    height: 80px;
}

.item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
}

.item-details {
    flex: 1;
}

.item-details h4 {
    margin: 0;
    font-size: 1.1em;
}

.price {
    color: #666;
    margin: 5px 0;
}

.item-quantity {
    display: flex;
    align-items: center;
    gap: 8px;
}

.quantity {
    min-width: 40px;
    text-align: center;
}

.item-total {
    font-weight: bold;
    min-width: 100px;
    text-align: right;
}

.remove-button {
    padding: 4px 8px;
}
</style>