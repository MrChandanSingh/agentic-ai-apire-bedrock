@using AspireApp.BedRock.PaymentGateway.Models
@using AspireApp.BedRock.PaymentGateway.Services
@inject IFishProductService FishProductService
@inject ICartService CartService

<div class="fish-listing">
    <h2 class="text-2xl font-bold mb-6">Fresh Fish Market</h2>

    @if (_loading)
    {
        <div class="flex justify-center items-center h-40">
            <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-blue-500"></div>
        </div>
    }
    else if (_error != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded" role="alert">
            <p>@_error</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var fish in _fishProducts)
            {
                <div class="fish-card bg-white rounded-lg shadow-md overflow-hidden">
                    <img src="@fish.ImageUrl" alt="@fish.Name" class="w-full h-48 object-cover" />
                    <div class="p-4">
                        <h3 class="text-xl font-semibold mb-2">@fish.Name</h3>
                        <p class="text-gray-600 mb-4">@fish.Description</p>
                        <div class="flex justify-between items-center">
                            <span class="text-lg font-bold text-blue-600">$@fish.Price.ToString("F2")</span>
                            <button @onclick="() => AddToCart(fish)" 
                                    class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-md transition-colors">
                                Add to Cart
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<FishProduct> _fishProducts = new();
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _fishProducts = await FishProductService.GetFishProductsAsync();
        }
        catch (Exception ex)
        {
            _error = "Failed to load fish products. Please try again later.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task AddToCart(FishProduct fish)
    {
        await CartService.AddToCartAsync(fish);
        // Optional: Add a toast notification here
    }
}